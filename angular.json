{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "bespoke": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/bespoke",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "assets": [
              "src/favicon.svg",
              "src/favicon.ico",
              "src/assets",
              "src/assets/images",
              "src/assets/audio",
              "src/assets/files/zine.pdf",
              {
                "glob": "**/*.wasm",
                "input": "projects/wasm-wrapper/src/lib/bespoke-wasm/pkg"
              }
            ],
            "styles": [
              "src/styles.scss",
              "node_modules/reveal.js/dist/reveal.css",
              "node_modules/reveal.js/css/theme/source/serif.scss",
              "src/app/talks/theme.scss"
            ],
            "scripts": [
              "node_modules/reveal.js/dist/reveal.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "2mb",
                  "maximumError": "4mb"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "100kb",
                  "maximumError": "200kb"
                }
              ],
              "outputHashing": "all"
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "bespoke:build:production"
            },
            "development": {
              "buildTarget": "bespoke:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n",
          "options": {
            "buildTarget": "bespoke:build"
          }
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "assets": [
              "src/favicon.svg",
              "src/favicon.ico",
              "src/assets",
              "src/assets/images",
              {
                "glob": "**/*.wasm",
                "input": "projects/wasm-wrapper/src/lib/bespoke-wasm/pkg"
              }
            ],
            "styles": [
              "src/styles.scss"
            ],
            "scripts": []
          }
        }
      }
    },
    "wasm-wrapper": {
      "projectType": "library",
      "root": "projects/wasm-wrapper",
      "sourceRoot": "projects/wasm-wrapper/src",
      "prefix": "lib",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:ng-packagr",
          "options": {
            "project": "projects/wasm-wrapper/ng-package.json"
          },
          "configurations": {
            "production": {
              "tsConfig": "projects/wasm-wrapper/tsconfig.lib.prod.json"
            },
            "development": {
              "tsConfig": "projects/wasm-wrapper/tsconfig.lib.json"
            }
          },
          "defaultConfiguration": "production"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "tsConfig": "projects/wasm-wrapper/tsconfig.spec.json",
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ]
          }
        }
      }
    }
  }
}
